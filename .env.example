# Naver Local Search API (사용자 키 미등록 시 fallback)
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# 공공데이터포털 API 키 (K-APT 아파트 단지 정보 보강)
# NAVER_CLIENT_ID/SECRET 이 함께 있으면 아파트 세대수·주차·입주일 자동 보강됨
# data.go.kr → K-APT 공동주택관리정보시스템 활용신청 키
DATA_GO_KR_API_KEY=your_data_go_kr_api_key_here

# 서울 열린데이터광장 API 키 (정비사업 현황 upisRebuild)
# 미설정 시 sample 키로 5건 smoke test만 가능합니다.
SEOUL_OPEN_API_KEY=your_seoul_open_data_api_key_here

# Database (defaults shown)
# DB_PATH=.cache/site-analysis.db
# JWT_SECRET_PATH=.cache/site-analysis.secret
